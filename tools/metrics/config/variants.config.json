{
  "$comment": "Descriptor for each SignalOps variant: where its source lives, what to measure, and how to attribute files. Shared 'socle' packages (contracts, fixtures, metrics, ui-spec, test-scenarios) are intentionally NOT attributed to any single variant so the comparison reflects variant-specific engineering. The `ci` block is the abstraction layer for the variant-level CI matrix (pass 2.5): per-variant build/typecheck/lint/test commands + Docker descriptor, so the heterogeneous toolchains (nx, pnpm filters, cargo/next) collect into one comparable JSON shape.",
  "collectorVersion": "1.1.0",
  "variants": [
    {
      "id": "flow",
      "label": "Flow",
      "thesis": "The balanced choice — modular, readable, and the cheapest to change.",
      "stack": "TanStack Start · React 19 · Vite · TypeScript",
      "accent": "#38e8c6",
      "roots": ["apps/flow-app", "packages/flow"],
      "dist": "apps/flow-app/dist/client",
      "dockerfiles": ["apps/flow-app/Dockerfile"],
      "appUrl": "http://localhost:3000",
      "apiUrl": null,
      "lighthouseUrlHint": "localhost:3000",
      "timings": {
        "build": "nx run flow-app:build --skip-nx-cache",
        "typecheck": "nx run flow-app:typecheck --skip-nx-cache",
        "test": "nx run flow-app:test --skip-nx-cache",
        "lint": "nx run flow-app:lint --skip-nx-cache"
      },
      "ci": {
        "testRunner": "vitest",
        "commands": {
          "build": "nx run flow-app:build --skip-nx-cache",
          "typecheck": "nx run flow-app:typecheck --skip-nx-cache",
          "lint": "nx run flow-app:lint --skip-nx-cache",
          "test": "nx run flow-app:test --skip-nx-cache"
        },
        "docker": {
          "enabled": true,
          "dockerfile": "apps/flow-app/Dockerfile",
          "context": ".",
          "image": "signalops-metrics-flow:ci",
          "port": 3000,
          "healthPath": "/api/health"
        }
      }
    },
    {
      "id": "friction",
      "label": "Friction",
      "thesis": "Locally fast, globally expensive — fewer parts, tangled and harder to trust.",
      "stack": "Vite · React · Express-style API · TypeScript",
      "accent": "#ff7a5c",
      "roots": ["apps/friction-web", "apps/friction-api"],
      "dist": "apps/friction-web/dist",
      "dockerfiles": ["apps/friction-web/Dockerfile", "apps/friction-api/Dockerfile"],
      "appUrl": null,
      "apiUrl": null,
      "lighthouseUrlHint": null,
      "timings": {
        "build": "pnpm --filter @signalops/friction-web --filter @signalops/friction-api run build",
        "typecheck": "pnpm --filter @signalops/friction-web --filter @signalops/friction-api run typecheck",
        "test": "pnpm --filter @signalops/friction-web --filter @signalops/friction-api run test",
        "lint": "pnpm --filter @signalops/friction-web --filter @signalops/friction-api run lint"
      },
      "ci": {
        "testRunner": "vitest",
        "commands": {
          "build": "pnpm --filter @signalops/friction-web --filter @signalops/friction-api run build",
          "typecheck": "pnpm --filter @signalops/friction-web --filter @signalops/friction-api run typecheck",
          "lint": "pnpm --filter @signalops/friction-web --filter @signalops/friction-api run lint",
          "test": "pnpm --filter @signalops/friction-web --filter @signalops/friction-api run test"
        },
        "docker": {
          "enabled": true,
          "$comment": "Friction ships two images (web + api); we build the user-facing web image for a comparable single-image size/startup signal. The api image is noted but not the scored artifact.",
          "dockerfile": "apps/friction-web/Dockerfile",
          "context": ".",
          "image": "signalops-metrics-friction-web:ci",
          "port": 3100,
          "healthPath": "/"
        }
      }
    },
    {
      "id": "overfit",
      "label": "Overfit",
      "thesis": "Technically impressive, dangerously expensive — over-engineered past its payoff.",
      "stack": "Next.js · Rust/Axum · CQRS · 17 crates + 14 packages",
      "accent": "#a98bff",
      "roots": ["apps/overfit-web", "apps/overfit-api", "packages/overfit", "crates"],
      "dist": "apps/overfit-web/.next/static",
      "dockerfiles": ["apps/overfit-web/Dockerfile", "apps/overfit-api/Dockerfile"],
      "appUrl": null,
      "apiUrl": null,
      "lighthouseUrlHint": null,
      "timings": {
        "build": "pnpm overfit:build",
        "typecheck": "pnpm overfit:typecheck",
        "test": "pnpm overfit:test",
        "lint": "pnpm overfit:boundaries"
      },
      "ci": {
        "testRunner": "vitest",
        "$comment": "test measures the TS/JS suite (`overfit:test`, vitest). The Rust `cargo test` suite is a separate gate (overfit:api:test) and is intentionally NOT folded into this duration so the number stays comparable to the other variants' vitest runs.",
        "commands": {
          "build": "pnpm overfit:build",
          "typecheck": "pnpm overfit:typecheck",
          "lint": "pnpm overfit:boundaries",
          "test": "pnpm overfit:test"
        },
        "docker": {
          "enabled": true,
          "$comment": "Overfit ships web (Next.js) + api (Rust) images; we build the user-facing web image for a comparable single-image signal.",
          "dockerfile": "apps/overfit-web/Dockerfile",
          "context": ".",
          "image": "signalops-metrics-overfit-web:ci",
          "port": 3300,
          "healthPath": "/"
        }
      }
    }
  ]
}
