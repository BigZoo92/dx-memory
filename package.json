{
  "name": "signalops-dx-lab",
  "version": "0.0.0",
  "private": true,
  "description": "SignalOps DX Lab — shared monorepo foundation for the three SignalOps variants (Friction / Flow / Overfit).",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "typecheck": "nx run-many -t typecheck",
    "lint": "nx run-many -t lint",
    "format": "oxfmt --ignore-path .oxfmtignore apps/flow-app/src packages/flow/*/src && prettier --write .",
    "format:check": "oxfmt --check --ignore-path .oxfmtignore apps/flow-app/src packages/flow/*/src && prettier --check .",
    "fixtures:generate": "pnpm --filter @signalops/fixtures generate",
    "metrics:collect": "pnpm --filter @signalops/metrics collect",
    "metrics:all": "pnpm fixtures:generate && pnpm metrics:collect",
    "metrics:dynamic": "node tools/metrics/collect.mjs",
    "metrics:dynamic:timings": "node tools/metrics/collect.mjs --timings",
    "metrics:variant": "node tools/metrics/collect-variant.mjs",
    "metrics:variant:all": "node tools/metrics/collect-variant.mjs --all",
    "metrics:dashboard": "pnpm --filter @signalops/metrics-dashboard dev",
    "metrics:dashboard:build": "node tools/metrics/collect.mjs --no-history && pnpm --filter @signalops/metrics-dashboard build",
    "build:flow": "nx run flow-app:build",
    "test:flow": "nx affected -t test --base=origin/main --head=HEAD",
    "typecheck:flow": "nx affected -t typecheck --base=origin/main --head=HEAD",
    "lint:flow": "nx affected -t lint --base=origin/main --head=HEAD",
    "ci:flow": "nx affected -t lint,typecheck,test,build --base=origin/main --head=HEAD",
    "docker:build:flow": "nx run flow-app:docker-build",
    "metrics:flow": "nx run flow-app:metrics",
    "analyze:flow": "ANALYZE=true nx run flow-app:build --skip-nx-cache",
    "audit:flow:boundaries": "depcruise --config .dependency-cruiser.cjs --output-type err apps/flow-app/src packages/flow",
    "audit:flow:cycles": "madge apps/flow-app/src packages/flow/domain/src packages/flow/effect/src packages/flow/observability/src packages/flow/server-data-access/src packages/flow/api-client/src packages/flow/ui/src packages/flow/feature-dashboard/src packages/flow/feature-signals/src packages/flow/feature-signal-detail/src packages/flow/feature-incidents/src packages/flow/feature-compare/src packages/flow/feature-dx-metrics/src packages/flow/feature-settings/src packages/flow/feature-ops/src --extensions ts,tsx --ts-config tsconfig.base.json --exclude 'routeTree\\.gen\\.ts' --circular",
    "audit:flow:knip": "knip --config knip.flow.json",
    "flow:doctor": "node scripts/flow/doctor.mjs",
    "flow:onboard": "node scripts/flow/onboard.mjs",
    "flow:setup": "pnpm install && pnpm fixtures:generate",
    "flow:dev": "nx run flow-app:dev",
    "flow:dev:clean": "rm -rf apps/flow-app/.output apps/flow-app/dist && nx run flow-app:dev",
    "flow:dev:docker": "nx run flow-app:docker-build && docker run --rm -p 3000:3000 signalops-flow:local",
    "flow:ci": "node scripts/flow/ci.mjs",
    "flow:ci:fast": "node scripts/flow/ci.mjs --fast",
    "flow:ci:full": "node scripts/flow/ci.mjs --full",
    "flow:ci:docker": "node scripts/flow/ci.mjs --docker",
    "flow:ci:act": "act -W .github/workflows/flow-ci.yml",
    "flow:a11y": "node scripts/flow/a11y.mjs",
    "flow:ai-pr-check": "node scripts/flow/ai-pr-check.mjs",
    "flow:ops:test": "pnpm --filter @signalops/flow-observability --filter @signalops/flow-feature-ops run test",
    "ci:friction": "pnpm --filter @signalops/friction-api --filter @signalops/friction-web run lint && pnpm --filter @signalops/friction-api --filter @signalops/friction-web run typecheck && pnpm --filter @signalops/friction-api --filter @signalops/friction-web run test && pnpm --filter @signalops/friction-api --filter @signalops/friction-web run build",
    "overfit:api:dev": "cargo run -p overfit-api",
    "overfit:api:test": "cargo test --workspace",
    "overfit:api:fmt": "cargo fmt --all",
    "overfit:api:clippy": "cargo clippy --workspace --all-targets",
    "overfit:api:build": "cargo build -p overfit-api --release",
    "overfit:web:dev": "pnpm --filter @signalops/overfit-web dev",
    "overfit:web:typecheck": "pnpm --filter @signalops/overfit-web typecheck",
    "overfit:web:test": "pnpm --filter @signalops/overfit-web test",
    "overfit:web:build": "pnpm --filter @signalops/overfit-web build",
    "overfit:contracts:generate": "node packages/overfit/quality-gates/scripts/generate-contracts.mjs",
    "overfit:contracts:check": "node packages/overfit/quality-gates/scripts/check-contracts.mjs",
    "overfit:schema:check": "node packages/overfit/quality-gates/scripts/check-schema.mjs",
    "overfit:policy:check": "node packages/overfit/quality-gates/scripts/check-policy.mjs",
    "overfit:docs:check": "node packages/overfit/quality-gates/scripts/check-docs.mjs",
    "overfit:quality": "node packages/overfit/quality-gates/scripts/quality.mjs",
    "overfit:typecheck": "pnpm --filter \"@signalops/overfit-*\" run typecheck",
    "overfit:test": "pnpm --filter \"@signalops/overfit-*\" run test",
    "overfit:build": "pnpm overfit:contracts:generate && pnpm overfit:web:build",
    "overfit:dev": "docker compose -f docker-compose.overfit.yml up --build",
    "overfit:boundaries": "depcruise --config .dependency-cruiser.overfit.cjs packages/overfit apps/overfit-web/app",
    "docker:build:overfit": "docker build -f apps/overfit-api/Dockerfile -t signalops-overfit-api:local . && docker build -f apps/overfit-web/Dockerfile -t signalops-overfit-web:local .",
    "ci:overfit": "pnpm overfit:contracts:check && pnpm overfit:quality && pnpm overfit:typecheck && pnpm overfit:test && pnpm overfit:web:build"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "^4.1.9",
    "dependency-cruiser": "^16.10.0",
    "knip": "^6.24.0",
    "madge": "^8.0.0",
    "nx": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "pa11y-ci": "^4.1.1",
    "prettier": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "vite": "npm:rolldown-vite@7.3.1",
      "@signalops/friction-web>vite": "7.3.6"
    }
  }
}
