{
  "name": "signalops-dx-lab",
  "version": "0.0.0",
  "private": true,
  "description": "SignalOps DX Lab — shared monorepo foundation for the three SignalOps variants (Friction / Flow / Overfit).",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "typecheck": "nx run-many -t typecheck",
    "lint": "nx run-many -t lint",
    "format": "oxfmt --ignore-path .oxfmtignore apps/flow-app/src packages/flow/*/src && prettier --write .",
    "format:check": "oxfmt --check --ignore-path .oxfmtignore apps/flow-app/src packages/flow/*/src && prettier --check .",
    "fixtures:generate": "pnpm --filter @signalops/fixtures generate",
    "metrics:collect": "pnpm --filter @signalops/metrics collect",
    "metrics:all": "pnpm fixtures:generate && pnpm metrics:collect",
    "dev:flow": "nx run flow-app:dev",
    "build:flow": "nx run flow-app:build",
    "test:flow": "nx affected -t test --base=origin/main --head=HEAD",
    "typecheck:flow": "nx affected -t typecheck --base=origin/main --head=HEAD",
    "lint:flow": "nx affected -t lint --base=origin/main --head=HEAD",
    "ci:flow": "nx affected -t lint,typecheck,test,build --base=origin/main --head=HEAD",
    "docker:build:flow": "nx run flow-app:docker-build",
    "metrics:flow": "nx run flow-app:metrics",
    "analyze:flow": "ANALYZE=true nx run flow-app:build --skip-nx-cache",
    "audit:flow:bundle": "ANALYZE=true nx run flow-app:build --skip-nx-cache",
    "audit:flow:boundaries": "depcruise --config .dependency-cruiser.cjs --output-type err apps/flow-app/src packages/flow",
    "audit:flow:cycles": "madge apps/flow-app/src packages/flow/domain/src packages/flow/effect/src packages/flow/server-data-access/src packages/flow/api-client/src packages/flow/ui/src packages/flow/feature-dashboard/src packages/flow/feature-signals/src packages/flow/feature-signal-detail/src packages/flow/feature-incidents/src packages/flow/feature-compare/src packages/flow/feature-dx-metrics/src packages/flow/feature-settings/src --extensions ts,tsx --ts-config tsconfig.base.json --exclude 'routeTree\\.gen\\.ts' --circular",
    "ci:friction": "echo \"Friction CI will be implemented in the variant pass\"",
    "ci:overfit": "echo \"Overfit CI will be implemented in the variant pass\""
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "^4.1.9",
    "dependency-cruiser": "^16.10.0",
    "madge": "^8.0.0",
    "nx": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "prettier": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "vite": "npm:rolldown-vite@7.3.1"
    }
  }
}
