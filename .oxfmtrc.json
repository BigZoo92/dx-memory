{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "singleQuote": true,
  "trailingComma": "none",
  "printWidth": 100,
  "tabWidth": 2,
  "arrowParens": "always",
  "ignorePatterns": [
    "**/dist/**",
    "**/dist-types/**",
    "**/.output/**",
    "**/.nitro/**",
    "**/.tanstack/**",
    "**/routeTree.gen.ts",
    "**/node_modules/**",
    "maquettes/**",
    "docs/**",
    "docker/**",
    "coverage/**",
    ".vscode/**",
    "apps/friction-api/**",
    "apps/friction-web/**",
    "apps/overfit-api/**",
    "apps/overfit-web/**",
    "packages/contracts/**",
    "packages/fixtures/**",
    "packages/metrics/**",
    "packages/test-scenarios/**",
    "packages/ui-spec/**",
    "packages/overfit/**",
    "packages/flow-domain/**",
    "packages/flow-ui/**",
    "packages/flow-data-access/**",
    "/vitest.config.ts",
    "/.dependency-cruiser.cjs",
    "/package.json"
  ]
}
