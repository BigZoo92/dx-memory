{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": false,
    "noEmit": true,
    "paths": {
      "@signalops/contracts": ["packages/contracts/src/index.ts"],
      "@signalops/fixtures": ["packages/fixtures/src/index.ts"],
      "@signalops/metrics": ["packages/metrics/src/index.ts"],
      "@signalops/test-scenarios": ["packages/test-scenarios/src/index.ts"],
      "@signalops/ui-spec": ["packages/ui-spec/src/index.ts"],
      "@signalops/flow-domain": ["packages/flow/domain/src/index.ts"],
      "@signalops/flow-effect": ["packages/flow/effect/src/index.ts"],
      "@signalops/flow-observability": ["packages/flow/observability/src/index.ts"],
      "@signalops/flow-observability/effect": ["packages/flow/observability/src/effect.ts"],
      "@signalops/flow-server-data-access": ["packages/flow/server-data-access/src/index.ts"],
      "@signalops/flow-api-client": ["packages/flow/api-client/src/index.ts"],
      "@signalops/flow-ui": ["packages/flow/ui/src/index.ts"],
      "@signalops/flow-feature-dashboard": ["packages/flow/feature-dashboard/src/index.ts"],
      "@signalops/flow-feature-signals": ["packages/flow/feature-signals/src/index.ts"],
      "@signalops/flow-feature-signal-detail": ["packages/flow/feature-signal-detail/src/index.ts"],
      "@signalops/flow-feature-incidents": ["packages/flow/feature-incidents/src/index.ts"],
      "@signalops/flow-feature-compare": ["packages/flow/feature-compare/src/index.ts"],
      "@signalops/flow-feature-dx-metrics": ["packages/flow/feature-dx-metrics/src/index.ts"],
      "@signalops/flow-feature-settings": ["packages/flow/feature-settings/src/index.ts"],
      "@signalops/flow-feature-ops": ["packages/flow/feature-ops/src/index.ts"],
      "@signalops/overfit-contracts-generated": ["packages/overfit/contracts-generated/src/index.ts"],
      "@signalops/overfit-api-client": ["packages/overfit/api-client/src/index.ts"],
      "@signalops/overfit-ui": ["packages/overfit/ui/src/index.ts"],
      "@signalops/overfit-feature-dashboard": ["packages/overfit/feature-dashboard/src/index.ts"],
      "@signalops/overfit-feature-signals": ["packages/overfit/feature-signals/src/index.ts"],
      "@signalops/overfit-feature-signal-detail": ["packages/overfit/feature-signal-detail/src/index.ts"],
      "@signalops/overfit-feature-incidents": ["packages/overfit/feature-incidents/src/index.ts"],
      "@signalops/overfit-feature-compare": ["packages/overfit/feature-compare/src/index.ts"],
      "@signalops/overfit-feature-dx-metrics": ["packages/overfit/feature-dx-metrics/src/index.ts"],
      "@signalops/overfit-feature-settings": ["packages/overfit/feature-settings/src/index.ts"],
      "@signalops/overfit-feature-ops": ["packages/overfit/feature-ops/src/index.ts"],
      "@signalops/overfit-quality-gates": ["packages/overfit/quality-gates/src/index.ts"],
      "@signalops/overfit-ai-governance": ["packages/overfit/ai-governance/src/index.ts"],
      "@signalops/overfit-generated-manifests": ["packages/overfit/generated-manifests/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
