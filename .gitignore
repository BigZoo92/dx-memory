# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
dist-types/
build/
*.tsbuildinfo

# TanStack Start / Nitro / Vite build artifacts
.output/
.nitro/
.tanstack/
.vinxi/

# Nx
.nx/cache
.nx/workspace-data

# Nx graph export assets (regenerate with `pnpm nx graph --file=...`)
docs/static/

# Collected per-app metrics report (regenerate with `nx run flow-app:metrics`)
apps/flow-app/metrics.flow.json

# Generated fixtures (run `pnpm fixtures:generate` to recreate)
packages/fixtures/data/*.json

# Generated metrics results (run `pnpm metrics:collect` to recreate)
# results.example.json is committed as a template and kept below.
packages/metrics/results/*.json
!packages/metrics/results/results.example.json

# Logs / env
*.log
.env
.env.*
!.env.example

# OS / editor
.DS_Store
.idea/
*.swp
