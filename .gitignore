# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
dist-types/
build/
*.tsbuildinfo

# TanStack Start / Nitro / Vite build artifacts
.output/
.nitro/
.tanstack/
.vinxi/

# Nx
.nx/cache
.nx/workspace-data

# Nx graph export assets (regenerate with `pnpm nx graph --file=...`)
docs/static/
docs/results-log-flow-graph.html

# Test coverage (regenerate with `nx run-many -t test --coverage`)
coverage/

# Flow audit artifacts — generated, regenerate with `pnpm flow:a11y` / `pnpm analyze:flow`.
# Only the explanatory README is versioned.
docs/audit/flow/*
!docs/audit/flow/README.md

# Collected per-app metrics report (regenerate with `nx run flow-app:metrics`)
apps/flow-app/metrics.flow.json

# Generated fixtures (run `pnpm fixtures:generate` to recreate)
packages/fixtures/data/*.json

# Generated metrics results (run `pnpm metrics:collect` to recreate)
# results.example.json is committed as a template and kept below.
packages/metrics/results/*.json
!packages/metrics/results/results.example.json

# Dynamic metrics pipeline (tools/metrics): commit latest + summary snapshots (the
# dashboard consumes summary/latest.json), but keep per-run history out of git —
# it is uploaded as a CI artifact instead of bloating the repo.
tools/metrics/results/history/*
!tools/metrics/results/history/.gitkeep

# Metrics dashboard build output
apps/metrics-dashboard/dist/

# Accessibility / Lighthouse audit artifacts (generated by pnpm flow:a11y)
.lighthouseci/
.pa11yci.runtime.json
.lighthouserc.runtime.json

# Logs / env
*.log
.env
.env.*
!.env.example
# Local-only GitHub metrics token/config (never committed; matched by .env.* above but
# listed explicitly — see tools/metrics/README.md → GitHub API integration).
.env.metrics.local

# OS / editor
.DS_Store
.idea/
*.swp

# Overfit (Variant C) — Rust build artifacts
/target/

# Overfit (Variant C) — Next.js build artifacts
apps/overfit-web/.next/
apps/overfit-web/.turbo/
apps/overfit-web/out/
