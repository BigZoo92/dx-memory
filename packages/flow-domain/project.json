{
  "name": "flow-domain",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/flow-domain/src",
  "tags": ["scope:flow", "type:domain"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": ["^typecheck"],
      "inputs": ["default", "^production"],
      "outputs": ["{projectRoot}/dist-types"],
      "cache": true,
      "options": { "command": "tsc -b tsconfig.json", "cwd": "packages/flow-domain" }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "outputs": ["{projectRoot}/dist-types"],
      "cache": true,
      "options": { "command": "tsc -b tsconfig.json", "cwd": "packages/flow-domain" }
    },
    "test": {
      "executor": "nx:run-commands",
      "inputs": ["default", "^production"],
      "cache": true,
      "options": { "command": "vitest run", "cwd": "packages/flow-domain" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "inputs": ["default"],
      "cache": true,
      "options": { "command": "oxlint src", "cwd": "packages/flow-domain" }
    }
  }
}
