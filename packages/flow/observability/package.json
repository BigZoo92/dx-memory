{
  "name": "@signalops/flow-observability",
  "version": "0.0.0",
  "private": true,
  "description": "Flow variant — local-first observability: structured log events, breadcrumbs, alert rules, redaction, diagnostic pack. Framework-free core; Effect logger adapter isolated under ./effect.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./effect": "./src/effect.ts"
  },
  "scripts": {
    "typecheck": "tsc -b tsconfig.json",
    "build": "tsc -b tsconfig.json",
    "test": "vitest run",
    "lint": "oxlint src"
  },
  "dependencies": {
    "@signalops/contracts": "workspace:*",
    "@signalops/flow-effect": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "oxlint": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
