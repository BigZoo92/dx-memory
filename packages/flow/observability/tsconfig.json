{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "./dist-types",
    "rootDir": "./src",
    "tsBuildInfoFile": "./dist-types/.tsbuildinfo"
  },
  "include": ["src"],
  "references": [
    {
      "path": "../../contracts"
    },
    {
      "path": "../effect"
    }
  ],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/**/test/**"]
}
