{
  "name": "@signalops/flow-ui",
  "version": "0.0.0",
  "private": true,
  "description": "Flow variant — reusable React components (CSS Modules), no API access.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles/tokens.css"
  },
  "scripts": {
    "typecheck": "tsc -b tsconfig.json",
    "build": "tsc -b tsconfig.json",
    "test": "vitest run",
    "lint": "oxlint src"
  },
  "dependencies": {
    "@signalops/contracts": "workspace:*",
    "@signalops/ui-spec": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "happy-dom": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
