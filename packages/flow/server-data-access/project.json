{
  "name": "flow-server-data-access",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/flow/server-data-access/src",
  "tags": ["scope:flow", "type:server", "type:data-access"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": ["^typecheck"],
      "inputs": ["default", "^production"],
      "outputs": ["{projectRoot}/dist-types"],
      "cache": true,
      "options": { "command": "tsc -b tsconfig.json", "cwd": "packages/flow/server-data-access" }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "outputs": ["{projectRoot}/dist-types"],
      "cache": true,
      "options": { "command": "tsc -b tsconfig.json", "cwd": "packages/flow/server-data-access" }
    },
    "test": {
      "executor": "nx:run-commands",
      "inputs": ["default", "^production"],
      "cache": true,
      "options": { "command": "vitest run", "cwd": "packages/flow/server-data-access" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "inputs": ["default"],
      "cache": true,
      "options": { "command": "oxlint src", "cwd": "packages/flow/server-data-access" }
    }
  }
}
